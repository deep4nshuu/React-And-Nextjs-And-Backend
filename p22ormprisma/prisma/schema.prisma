generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String

  createdAt DateTime
  updatedAt DateTime @updatedAt
}

model Post {
  id String @id @default(cuid())
  title String 
  content String?
  updatedAt DateTime @updatedAt
}